# ============================================================
# BTC Swing Trading Agent - Environment Variables Template
# Copy this to .env and fill in your real values
# NEVER commit .env to git
# ============================================================

# Coinbase Advanced Trade API (TRADE-ONLY scope — no withdrawal permission)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Dashboard Auth Token (Phase 3)
DASHBOARD_AUTH_TOKEN=change_me_to_a_random_secret
